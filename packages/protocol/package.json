{
  "name": "@workspace/protocol",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "codex:generate": "node ./scripts/generate-codex-types.mjs && node ./scripts/generate-codex-json-schema.mjs",
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-generated-assets.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
